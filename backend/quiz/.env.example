# Quiz Generator API Key (Can be Gemini or Groq)
# If a Groq key (gsk_...) is placed here, the quiz generator will automatically use Groq.
GEMINI_API_KEY=

# AI Tutor Groq API Key (starts with gsk_)
GROQ_API_KEY=

# OpenAI API Key (starts with sk-) used for Voice transcription or fallback
OPENAI_API_KEY=